OPENROUTER_API_KEY=sk-or-...
LLM_BACKEND=ollama
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
SUMMARY_LANGUAGE=it
OUTPUT_DIR=output

# Ollama (default backend per summarization locale)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0.3

# llama.cpp server (LLM_BACKEND=llamacpp)
LLAMACPP_BASE_URL=http://localhost:8080
LLAMACPP_MODEL=default

# vLLM (LLM_BACKEND=vllm)
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=default

# Chunking / reduce
SEGMENT_DURATION_SEC=300
REDUCE_BATCH_SIZE=6
REDUCE_MAX_INPUT_CHARS=12000
